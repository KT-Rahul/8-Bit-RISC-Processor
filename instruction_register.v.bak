module instruction_register (
    input clk,
    input reset,
    input [15:0] instruction_in,
    input ir_load,

    output reg [15:0] instruction_out
);

always @(posedge clk or posedge reset) begin
    if (reset) begin
        instruction_in <= 16'b0;
    end
    else if (ir_load) begin
        instruction_out <= instruction_in;
    end
end
    
endmodule