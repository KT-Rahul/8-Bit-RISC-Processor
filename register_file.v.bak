module register_file(clk, reset, w_enable, w_address, w_data, raddress1, raddress2, rdata1, rdata2);

input clk, reset, w_enable;
input [1:0] w_address, raddress1, raddress2;
input [7:0] w_data;
output reg [7:0] rdata1, rdata2;


reg [7:0] register [0:3];

// Combinational Logic
always @(*) begin
    case (raddress1)
    2'b00: rdata1 = r[0];
    2'b01: rdata1 = r[1];
    2'b10: rdata1 = r[2];
    2'b11: rdata1 = r[3];
    endcase
end

always @(*) begin
    case (raddress2)
    2'b00: rdata2 = r[0];
    2'b01: rdata2 = r[1];
    2'b10: rdata2 = r[2];
    2'b11: rdata2 = r[3];
    endcase
end

// Sequential Logic
always @(posedge clk or posedge reset) begin
    if (reset) begin
        r[0] <= 8'b0;
        r[1] <= 8'b0;
        r[2] <= 8'b0;
        r[3] <= 8'b0;
    end

    else if (w_enable) begin
        case (w_address)
            2'b00: r[0] <= w_data;
            2'b01: r[1] <= w_data;
            2'b10: r[2] <= w_data;
            2'b11: r[3] <= w_data;
        endcase
    end

end


endmodule